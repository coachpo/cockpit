# Edit this file before running `docker compose` from `deploy/`.
# Pass it through `docker compose --env-file ./env.example ...` when you want the
# compose-level port overrides below to apply during interpolation.
# It is also loaded into the backend container by `deploy/docker-compose.yml`.
# The frontend can be deployed separately; in this compose stack it is still served
# through nginx, while the backend is also published directly for cross-origin access.

# Host ports published by the compose stack.
BACKEND_PORT=8080
FRONTEND_PORT=80

# -----------------------------------------------------------------------------
# Backend runtime bootstrap
# -----------------------------------------------------------------------------
# Cockpit still expects a config-path value internally, but this compose stack does
# not seed or rely on a local YAML config file. Live config/auth bootstrap comes from Nacos.

# Required for remote management through the compose stack or a separately deployed frontend.
MANAGEMENT_PASSWORD=change-this-before-production

# Required backend bootstrap. Set this to a reachable Nacos host:port before using
# the compose stack; the current backend entrypoint loads config/auth from Nacos.
# `NACOS_CACHE_DIR` stays mounted in the compose stack for writable runtime state.
NACOS_ADDR=
NACOS_NAMESPACE=public
NACOS_GROUP=DEFAULT_GROUP
NACOS_USERNAME=
NACOS_PASSWORD=
NACOS_CACHE_DIR=/tmp/nacos/cache
