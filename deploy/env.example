# Edit this file before running `docker compose` from `deploy/`.
# It is loaded into the backend container by `deploy/docker-compose.yml`.

# -----------------------------------------------------------------------------
# Backend runtime bootstrap
# -----------------------------------------------------------------------------
# Static deployments should keep DEPLOY blank so Cockpit requires a real config
# file at startup instead of waiting in cloud standby mode.
DEPLOY=

# Required for remote management through the reverse proxy.
MANAGEMENT_PASSWORD=change-this-before-production

# Optional Nacos bootstrap. Leave blank for static file mode.
NACOS_ADDR=
NACOS_NAMESPACE=public
NACOS_GROUP=DEFAULT_GROUP
NACOS_USERNAME=
NACOS_PASSWORD=
NACOS_CACHE_DIR=/tmp/nacos/cache
